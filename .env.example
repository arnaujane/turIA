# Frontend map integration
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_API_BASE_URL=http://localhost:3000

# Google Cloud shared project configuration
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
GOOGLE_CLOUD_REGION=europe-southwest1

# Firestore logical references for Persona 3 contracts
FIRESTORE_USERS_COLLECTION=users
FIRESTORE_PROGRESS_SUBCOLLECTION=progress
FIRESTORE_ROUTES_COLLECTION=routes
FIRESTORE_DEMO_ROUTE_ID=demo-route

# Demo behavior flags
DEMO_ROUTE_LOCALE=es-ES
DEMO_USE_STATIC_FALLBACKS=true
DEMO_ENABLE_MOCK_PROGRESS=true

